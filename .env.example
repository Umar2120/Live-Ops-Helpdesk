# Vercel frontend URL. Set this on the Render backend.
FRONTEND_URL=https://live-ops-helpdesk.vercel.app/

# Comma-separated production origins allowed to use REST + Socket.io.
# Set this on the Render backend. Do not use "*" in production.
API_ALLOWED_ORIGINS=https://live-ops-helpdesk.vercel.app/
SOCKET_ALLOWED_ORIGINS=https://live-ops-helpdesk.vercel.app/

# Render backend URL. Set these on the Vercel frontend.
# Use https:// for Socket.io; the browser upgrades to WSS automatically.
NEXT_PUBLIC_API_URL=https://live-ops-helpdesk-cbhn.onrender.com/
NEXT_PUBLIC_SOCKET_URL=https://live-ops-helpdesk-cbhn.onrender.com/
NEXT_PUBLIC_SOCKET_PATH=/api/socket
